# Copy to .env.local and fill in values

# Any reachable Postgres — a local install, or a free hosted instance
# (Neon, Supabase, Railway, etc.).
DATABASE_URL=postgresql://user:password@localhost:5432/app

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Only needed locally — on Vercel this falls back to the deployment's own
# URL automatically, so you don't need to set it in Vercel project env vars.
BETTER_AUTH_URL=http://localhost:3000
